# Civic Hero Trust & Operations Console — Environment Variables
# Copy this file to .env.local and fill in the values.

# ── Supabase (same project as the mobile app) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://joxliieaxokhptnwuckd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — used for server-side admin queries only.
# NEVER expose this in the browser. Server Components / Route Handlers only.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Console config ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_CONSOLE_VERSION=1.0.0
